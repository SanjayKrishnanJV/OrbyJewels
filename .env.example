# ============================================================
# ORBY JEWELS - Environment Variables
# Copy this file to .env.local and fill in your values
# ALL SERVICES USED ARE FREE TIER
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Orby Jewels"

# ============================================================
# DATABASE - Neon PostgreSQL (FREE TIER)
# Sign up at: https://neon.tech
# Create project → copy "DATABASE_URL (with pooling)" string
# ============================================================
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# AUTHENTICATION - NextAuth v5 (FREE)
# Generate secret: run this in terminal:
#   openssl rand -base64 32
# Both vars must have the same value
# ============================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=paste_your_generated_secret_here
AUTH_SECRET=paste_your_generated_secret_here

# Google OAuth (FREE) - optional, lets users sign in with Google
# Steps: console.cloud.google.com → New Project → OAuth 2.0 Client
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================================
# IMAGE STORAGE - Cloudinary (FREE TIER - 25GB)
# Sign up at: https://cloudinary.com
# Dashboard → Account Details → Cloud name, API Key, API Secret
# Also create an upload preset: Settings → Upload → Add preset
#   Preset name: orby_jewels_upload, Signing mode: Unsigned
# ============================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=orby_jewels_upload

# ============================================================
# EMAIL - Resend (FREE TIER - 3000 emails/month)
# Sign up at: https://resend.com → API Keys → Create
# ============================================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@orbyjewels.com

# ============================================================
# PAYMENT - Manual UPI (NO KEYS NEEDED)
# UPI ID and QR code are configured in Admin → Settings
# No API keys required for UPI payments
# ============================================================

# ============================================================
# ADMIN CREDENTIALS (set these in the seed file)
# ============================================================
ADMIN_EMAIL=admin@orbyjewels.com
ADMIN_PASSWORD=OrbyAdmin@2024
